<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE jasperReport PUBLIC "-//JasperReports//DTD Report Design//EN"
        "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport name="servicios" language="java" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="peluqueria"/>
	<queryString language="SQL"><![CDATA[
		SELECT s.id, s.nombre, s.precio, CONCAT(u.nombre, ' ', u.apellido) AS nombreEmpleado
		FROM servicios s
		LEFT JOIN usuarios u ON s.idEmpleado = u.id
	]]></queryString>
	<field name="id" class="java.lang.Integer"/>
	<field name="nombre" class="java.lang.String"/>
	<field name="precio" class="java.lang.Double"/>
	<field name="nombreEmpleado" class="java.lang.String"/>
	<background>
		<band height="0"/>
	</background>
	<title>
		<band height="134">
			<image>
				<reportElement x="0" y="0" width="65" height="60"/>
				<imageExpression><![CDATA[getClass().getResource("/images/logo.png")]]></imageExpression>
			</image>
			<staticText>
				<reportElement x="95" y="0" width="210" height="25"/>
				<textElement>
					<font size="19" isBold="true"/>
				</textElement>
				<text><![CDATA[Hector Yagusz]]></text>
			</staticText>
			<staticText>
				<reportElement x="95" y="25" width="205" height="15"/>
				<text><![CDATA[España 2856]]></text>
			</staticText>
			<staticText>
				<reportElement x="95" y="40" width="205" height="15"/>
				<text><![CDATA[Posadas, Misiones 3300]]></text>
			</staticText>
			<staticText>
				<reportElement x="415" y="10" width="50" height="20"/>
				<textElement textAlignment="Right"/>
				<text><![CDATA[Fecha:]]></text>
			</staticText>
			<textField pattern="d/M/yyyy h:mm a">
				<reportElement x="465" y="10" width="100" height="20"/>
				<textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
			</textField>
			<line>
				<reportElement x="0" y="80" width="535" height="1"/>
			</line>
			<staticText>
				<reportElement positionType="FixRelativeToBottom" stretchType="RelativeToBandHeight" x="80" y="80" width="399" height="49"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font size="20" isUnderline="true"/>
				</textElement>
				<text><![CDATA[Servicios]]></text>
			</staticText>
		</band>
	</title>
	<columnHeader>
		<band height="27">
			<rectangle>
				<reportElement x="0" y="0" width="535" height="20" backcolor="#DED1ED"/>
				<graphicElement>
					<pen lineColor="#E0E0E0"/>
				</graphicElement>
			</rectangle>
			<staticText>
				<reportElement x="0" y="0" width="80" height="19"/>
				<textElement><font isBold="true"/></textElement>
				<text><![CDATA[ID]]></text>
			</staticText>
			<staticText>
				<reportElement x="80" y="0" width="150" height="19"/>
				<textElement><font isBold="true"/></textElement>
				<text><![CDATA[Servicio]]></text>
			</staticText>
			<staticText>
				<reportElement x="230" y="0" width="100" height="19"/>
				<textElement><font isBold="true"/></textElement>
				<text><![CDATA[Precio]]></text>
			</staticText>
			<staticText>
				<reportElement x="330" y="0" width="205" height="19"/>
				<textElement><font isBold="true"/></textElement>
				<text><![CDATA[Responsable]]></text>
			</staticText>
		</band>
	</columnHeader>
	<detail>
		<band height="25">
			<textField isBlankWhenNull="true">
				<reportElement x="0" y="0" width="80" height="20"/>
				<textFieldExpression><![CDATA[$F{id}]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement x="80" y="0" width="150" height="20"/>
				<textFieldExpression><![CDATA[$F{nombre}]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement x="230" y="0" width="100" height="20"/>
				<textFieldExpression><![CDATA[$F{precio}]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement x="330" y="0" width="205" height="20"/>
				<textFieldExpression><![CDATA[$F{nombreEmpleado}]]></textFieldExpression>
			</textField>
			<line>
				<reportElement x="0" y="23" width="535" height="1"/>
			</line>
		</band>
	</detail>
	<pageFooter>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE jasperReport PUBLIC "-//JasperReports//DTD Report Design//EN"
        "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport name="turnos" language="java" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="peluqueria"/>
	<queryString language="SQL"><![CDATA[
		SELECT
			t.id,
			t.detalle,
			t.estado,
			DATE_FORMAT(t.fecha, '%d/%m/%Y %H:%i') AS fechaFormateada,
			CONCAT(c.nombre, ' ', c.apellido) AS nombreCliente,
			s.nombre AS nombreServicio
		FROM turno t
		LEFT JOIN clientes c ON t.cliente = c.id
		LEFT JOIN servicios s ON t.servicio = s.id
	]]></queryString>
	<field name="id" class="java.lang.Integer"/>
	<field name="detalle" class="java.lang.String"/>
	<field name="estado" class="java.lang.String"/>
	<field name="fechaFormateada" class="java.lang.String"/>
	<field name="nombreCliente" class="java.lang.String"/>
	<field name="nombreServicio" class="java.lang.String"/>
	<background>

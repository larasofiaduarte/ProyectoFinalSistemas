			</staticText>
			<staticText>
				<reportElement x="95" y="40" width="205" height="15"/>
				<text><![CDATA[Posadas, Misiones 3300]]></text>
			</staticText>
			<staticText>
				<reportElement x="410" y="0" width="50" height="20"/>
				<textElement textAlignment="Right"/>
				<text><![CDATA[Fecha:]]></text>
			</staticText>
			<textField pattern="d/M/yyyy h:mm a">
				<reportElement x="460" y="0" width="100" height="20"/>
				<textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
			</textField>
			<line>
				<reportElement x="0" y="80" width="535" height="1"/>
			</line>
			<staticText>
				<reportElement positionType="FixRelativeToBottom" stretchType="RelativeToBandHeight" x="80" y="80" width="399" height="49"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font size="20" isUnderline="true"/>
				</textElement>
				<text><![CDATA[Turnos]]></text>
			</staticText>
		</band>
	</title>
	<columnHeader>
		<band height="20">
			<rectangle>
				<reportElement x="0" y="0" width="535" height="20" backcolor="#DED1ED"/>
				<graphicElement>
					<pen lineColor="#E0E0E0"/>
				</graphicElement>
			</rectangle>
			<staticText>
				<reportElement x="0" y="0" width="30" height="20"/>
				<textElement><font isBold="true"/></textElement>
				<text><![CDATA[ID]]></text>
			</staticText>
			<staticText>
				<reportElement x="30" y="0" width="80" height="20"/>
				<textElement><font isBold="true"/></textElement>
				<text><![CDATA[Detalle]]></text>
			</staticText>
			<staticText>
				<reportElement x="110" y="0" width="60" height="20"/>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE jasperReport PUBLIC "-//JasperReports//DTD Report Design//EN"
        "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport name="inventario" language="java" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="peluqueria"/>
	<queryString language="SQL"><![CDATA[
		SELECT p.id, p.nombre, p.stock, p.minimo, pr.nombre AS nombreProveedor
		FROM productos p
		LEFT JOIN proveedores pr ON p.idProveedor = pr.id
	]]></queryString>
	<field name="id" class="java.lang.Integer"/>
	<field name="nombre" class="java.lang.String"/>
	<field name="stock" class="java.lang.Double"/>
	<field name="minimo" class="java.lang.Double"/>
	<field name="nombreProveedor" class="java.lang.String"/>
	<background>
		<band height="0"/>
	</background>
	<title>
		<band height="129">
			<image>
				<reportElement x="0" y="0" width="65" height="60"/>
				<imageExpression><![CDATA[getClass().getResource("/images/logo.png")]]></imageExpression>
			</image>
			<staticText>
				<reportElement x="95" y="0" width="210" height="25"/>
				<textElement>
					<font size="19" isBold="true"/>
				</textElement>
				<text><![CDATA[Hector Yagusz]]></text>
			</staticText>
			<staticText>
				<reportElement x="95" y="25" width="205" height="15"/>
				<text><![CDATA[España 2856]]></text>
			</staticText>
			<staticText>
				<reportElement x="95" y="40" width="205" height="15"/>
				<text><![CDATA[Posadas, Misiones 3300]]></text>
			</staticText>
			<staticText>
				<reportElement x="415" y="10" width="50" height="20"/>
				<textElement textAlignment="Right"/>
				<text><![CDATA[Fecha:]]></text>
			</staticText>
			<textField pattern="d/M/yyyy h:mm a">
				<reportElement x="465" y="10" width="100" height="20"/>
				<textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
			</textField>
			<line>
				<reportElement x="0" y="80" width="535" height="1"/>
			</line>
			<staticText>
				<reportElement positionType="FixRelativeToBottom" stretchType="RelativeToBandHeight" x="80" y="80" width="399" height="49"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font size="20" isUnderline="true"/>
				</textElement>
				<text><![CDATA[Report de Stock]]></text>
			</staticText>
		</band>
	</title>
	<columnHeader>
		<band height="20">
			<rectangle>
				<reportElement x="0" y="0" width="535" height="20" backcolor="#DED1ED"/>
				<graphicElement>
					<pen lineColor="#E0E0E0"/>
				</graphicElement>
			</rectangle>
			<staticText>
				<reportElement x="0" y="0" width="80" height="19"/>
				<textElement><font isBold="true"/></textElement>
				<text><![CDATA[ID]]></text>
			</staticText>
			<staticText>
				<reportElement x="80" y="0" width="100" height="19"/>
				<textElement><font isBold="true"/></textElement>
				<text><![CDATA[Producto]]></text>
			</staticText>
			<staticText>
				<reportElement x="180" y="0" width="100" height="19"/>
				<textElement><font isBold="true"/></textElement>
				<text><![CDATA[Stock]]></text>
			</staticText>
			<staticText>
				<reportElement x="280" y="0" width="100" height="19"/>
				<textElement><font isBold="true"/></textElement>
				<text><![CDATA[Minimo]]></text>
			</staticText>
			<staticText>
				<reportElement x="380" y="0" width="155" height="19"/>
				<textElement><font isBold="true"/></textElement>
				<text><![CDATA[Proveedor]]></text>
			</staticText>
		</band>
	</columnHeader>
	<detail>
		<band height="30">
			<textField>
				<reportElement x="0" y="5" width="80" height="20"/>
				<textFieldExpression><![CDATA[$F{id}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="80" y="5" width="100" height="20"/>
				<textFieldExpression><![CDATA[$F{nombre}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="180" y="5" width="100" height="20"/>
				<textFieldExpression><![CDATA[$F{stock}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="280" y="5" width="100" height="20"/>
				<textFieldExpression><![CDATA[$F{minimo}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="380" y="5" width="155" height="20"/>
